<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>
        <h2>Upcoming Service Projects</h2>

        <% if (projects && projects.length) { %>
            <ul>
                <% projects.forEach(project=> { %>
                    <% const formattedDate=project.date ? new Date(project.date).toLocaleDateString('en-US', {
                        month: 'long' , day: 'numeric' , year: 'numeric' }) : 'TBD' ; %>
                        <li>
                            Date: <%= formattedDate %> - <strong>
                                    <%= project.title %>
                                </strong> (<%= project.organization_name %>)
                                    <p>
                                        <%= project.description %>
                                    </p>
                                    <p><em>
                                            <%= project.location %>
                                        </em></p>
                        </li>
                        <% }) %>
            </ul>
            <% } else { %>
                <p>No service projects were found.</p>
                <% } %>
    </main>

    <%- include('partials/footer') %>